# Shopify Store Configuration
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token
VITE_SHOPIFY_API_KEY=your_api_key
VITE_SHOPIFY_API_SECRET=your_api_secret
VITE_SHOPIFY_API_VERSION=2024-10

# Environment
VITE_SHOPIFY_ENVIRONMENT=development

# Optional
VITE_SHOPIFY_ENABLE_MOCK=false
VITE_SHOPIFY_ENABLE_LOGGING=true
VITE_SHOPIFY_ENABLE_DIAGNOSTICS=false
VITE_SHOPIFY_TIMEOUT=10000
VITE_SHOPIFY_RETRY_ATTEMPTS=3
VITE_SHOPIFY_MAX_RETRIES=3
VITE_SHOPIFY_RETRY_DELAY=1000
